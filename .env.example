# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the real .env to git -- it's already in .gitignore.

# ── Required for deployment ───────────────────────────────────────────────────

# Private key of the testnet wallet that deploys DexDealChecker.
# Get testnet RITUAL at: https://faucet.ritualfoundation.org
# Format: 0x-prefixed hex, e.g. 0xabc123...
# Read by Deploy.s.sol via vm.envUint("PRIVATE_KEY").
# Use a DEDICATED testnet-only key -- not a wallet holding real funds anywhere.
PRIVATE_KEY=0x9693da964f9e1b51fff23b820412b547bea8ed108804d7b77cd609f5081d6b10

# Ritual Chain RPC endpoint (public, no API key needed)
RITUAL_RPC_URL=https://rpc.ritualfoundation.org

# ── Required for contract verification (optional, do after deploy) ─────────────

# Ritual's custom verification API -- NOT Sourcify (chain 1979 isn't registered).
# Pass as: forge verify-contract --verifier custom --verifier-url "$RITUAL_VERIFIER_URL" --verifier-api-key unused
RITUAL_VERIFIER_URL=https://rpc.ritualfoundation.org/api/verify

# ── Required for scripts/check-token.mjs ─────────────────────────────────────

# Fill in after running Deploy.s.sol -- the address logged to console.
CONTRACT_ADDRESS=
